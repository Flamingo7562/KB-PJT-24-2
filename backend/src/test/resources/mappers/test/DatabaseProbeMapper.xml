<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gighub.config.DatabaseProbeMapper">
    <select id="selectDatabaseName" resultType="string">
        SELECT DATABASE()
    </select>

    <select id="countUsers" resultType="long">
        SELECT COUNT(*)
        FROM users
    </select>
</mapper>
